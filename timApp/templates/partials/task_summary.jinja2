<div class="taskSummary" id="task-point-summary">
    <span>
    <strong>{{ gettext("Task Summary") }}</strong>
        {% if not task_info.hide_total_points -%}
        {{ gettext("Total points") }}: {{ task_info.total_points }}&nbsp;
        {%- endif -%}
        {%- if task_info.groups %}
        {%- if task_info.breaklines %}
                <br>
        {%- for k, v in task_info.groups.items() -%}
        {{ v.text|safe}}{%- if v.link %} <a href="{{ v.link}}">{{ v.linktext }}</a>{%- endif -%}<br>
        {%- endfor -%}
        {%- else -%}
                ({%- for k, v in task_info.groups.items() -%}
        {{ v.text }}{% if not loop.last %}, {% endif %}
        {%- endfor -%}),&nbsp;
        {%- endif -%}
        {%- endif -%}
        {%- if not task_info.hide_total_tasks  -%}
        {{ gettext("total tasks") }}: {{ task_info.tasks_done }}&nbsp;/&nbsp;{{ task_info.total_tasks }}
        {% endif -%}
    </span>
    <span class="refresh-notice" style="font-size: x-small;" ng-click="reload()">{{ gettext("Refresh (F5) to recount") }}</span>
</div>
<div class="taskSmallSummary" id="task-point-summary-small"><p>{{ task_info.total_points }} p</p></div>